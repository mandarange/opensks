{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitCreateBranch",
  "description": "The result of creating a local branch.",
  "type": "object",
  "required": [
    "branch",
    "created",
    "head",
    "schema"
  ],
  "properties": {
    "branch": {
      "type": "string"
    },
    "created": {
      "type": "boolean"
    },
    "head": {
      "description": "The commit the new branch points at.",
      "type": "string"
    },
    "schema": {
      "type": "string"
    }
  }
}
