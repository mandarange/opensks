{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EngineRequest",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/EngineRequestKind"
    },
    "params": {
      "default": {},
      "allOf": [
        {
          "$ref": "#/definitions/EngineRequestParams"
        }
      ]
    },
    "protocol_version": {
      "default": "",
      "type": "string"
    },
    "schema": {
      "type": "string"
    }
  },
  "definitions": {
    "ConversationTurnSettings": {
      "description": "Effective settings applied to one turn.",
      "type": "object",
      "required": [
        "approval_policy_id",
        "execution_mode",
        "max_parallelism",
        "model",
        "pipeline_id",
        "reasoning_effort",
        "tool_policy_id",
        "verifier_count"
      ],
      "properties": {
        "approval_policy_id": {
          "type": "string"
        },
        "cost_budget_usd": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "execution_mode": {
          "$ref": "#/definitions/ExecutionMode"
        },
        "graph_revision": {
          "type": [
            "string",
            "null"
          ]
        },
        "image_model_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "max_parallelism": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "model": {
          "$ref": "#/definitions/ModelSelection"
        },
        "pipeline_id": {
          "type": "string"
        },
        "reasoning_effort": {
          "$ref": "#/definitions/ReasoningEffort"
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "token_budget": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "tool_policy_id": {
          "type": "string"
        },
        "verifier_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ConversationTurnStartRequest": {
      "description": "Submitted by the app to start a turn. The daemon validates and replies with [`ConversationTurnAccepted`] without waiting for the run to complete.",
      "type": "object",
      "required": [
        "client_turn_id",
        "conversation_id",
        "idempotency_key",
        "message",
        "project_id",
        "request_id",
        "schema"
      ],
      "properties": {
        "client_turn_id": {
          "type": "string"
        },
        "context": {
          "default": {},
          "allOf": [
            {
              "$ref": "#/definitions/TurnContextSelection"
            }
          ]
        },
        "conversation_id": {
          "type": "string"
        },
        "idempotency_key": {
          "type": "string"
        },
        "message": {
          "$ref": "#/definitions/UserMessageInput"
        },
        "project_id": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        },
        "settings": {
          "description": "Legacy compatibility echo from older clients. Runtime settings are always snapshotted from durable thread settings instead.",
          "anyOf": [
            {
              "$ref": "#/definitions/ConversationTurnSettings"
            },
            {
              "type": "null"
            }
          ]
        },
        "thread_settings_updated_at_ms": {
          "description": "Client-observed durable thread settings revision. The daemon uses this as a compare-and-snapshot guard before accepting a turn.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "EngineRequestKind": {
      "type": "string",
      "enum": [
        "hello",
        "health",
        "subscribe_events",
        "conversation_turn_start",
        "conversation_supervisor_tick",
        "integration_candidate_apply",
        "worktree_inventory",
        "worktree_recover",
        "run_start",
        "run_pause",
        "run_resume",
        "run_cancel",
        "run_steer",
        "approval_request",
        "approval_approve",
        "approval_deny",
        "outbox_dispatch"
      ]
    },
    "EngineRequestParams": {
      "type": "object",
      "properties": {
        "approval_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "conversation_turn_start": {
          "anyOf": [
            {
              "$ref": "#/definitions/ConversationTurnStartRequest"
            },
            {
              "type": "null"
            }
          ]
        },
        "graph_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "lease_ttl_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "objective": {
          "type": [
            "string",
            "null"
          ]
        },
        "pipeline_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "poll_interval_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "reason_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "since_sequence": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "supervisor_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "tail_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "target_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ExecutionMode": {
      "description": "Where a turn is allowed to write (§5.4). `Cloud` is reserved and hidden until a real adapter exists.",
      "type": "string",
      "enum": [
        "local",
        "worktree",
        "read_only",
        "cloud"
      ]
    },
    "ModelSelection": {
      "description": "Model choice for a turn/thread. A single configured model auto-selects.",
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "fallback_model_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mode": {
          "$ref": "#/definitions/ModelSelectionMode"
        },
        "model_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ModelSelectionMode": {
      "description": "Whether the model is auto-routed or pinned by the user.",
      "type": "string",
      "enum": [
        "auto",
        "pinned"
      ]
    },
    "ReasoningEffort": {
      "description": "User-facing reasoning effort. Adapters map these to provider-specific knobs; an adapter that cannot honour a value reports `unsupported` rather than silently ignoring it (§5.3).",
      "type": "string",
      "enum": [
        "quick",
        "standard",
        "deep",
        "maximum"
      ]
    },
    "TurnContextSelection": {
      "description": "Context the user explicitly selected for this turn (files, ranges, symbols, diffs, etc.), carried as opaque refs the context assembler resolves.",
      "type": "object",
      "properties": {
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "UserMessageInput": {
      "description": "The user's message text plus any attachment/context artifact refs.",
      "type": "object",
      "required": [
        "text"
      ],
      "properties": {
        "attachment_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "text": {
          "type": "string"
        }
      }
    }
  }
}
