{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EngineRequest",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/EngineRequestKind"
    },
    "params": {
      "default": {},
      "allOf": [
        {
          "$ref": "#/definitions/EngineRequestParams"
        }
      ]
    },
    "protocol_version": {
      "default": "",
      "type": "string"
    },
    "schema": {
      "type": "string"
    }
  },
  "definitions": {
    "EngineRequestKind": {
      "type": "string",
      "enum": [
        "hello",
        "health",
        "subscribe_events",
        "run_start",
        "run_pause",
        "run_resume",
        "run_cancel",
        "run_steer",
        "approval_request",
        "approval_approve",
        "approval_deny",
        "outbox_dispatch"
      ]
    },
    "EngineRequestParams": {
      "type": "object",
      "properties": {
        "approval_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "graph_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "objective": {
          "type": [
            "string",
            "null"
          ]
        },
        "pipeline_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "poll_interval_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "reason_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "since_sequence": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "tail_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "target_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
