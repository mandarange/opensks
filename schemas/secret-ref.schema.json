{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecretRef",
  "type": "object",
  "required": [
    "account",
    "schema",
    "service",
    "store",
    "version"
  ],
  "properties": {
    "account": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "service": {
      "type": "string"
    },
    "store": {
      "$ref": "#/definitions/SecretStoreKind"
    },
    "version": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "SecretStoreKind": {
      "type": "string",
      "enum": [
        "macos_keychain",
        "external_broker",
        "local_development",
        "test_memory"
      ]
    }
  }
}
