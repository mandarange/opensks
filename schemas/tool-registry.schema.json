{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolRegistry",
  "description": "A registry snapshot for the tools known to the current runtime.",
  "type": "object",
  "required": [
    "registry_id",
    "revision",
    "schema",
    "tools"
  ],
  "properties": {
    "registry_id": {
      "type": "string"
    },
    "revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "schema": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ToolDescriptor"
      }
    }
  },
  "definitions": {
    "ToolAvailability": {
      "description": "Whether a tool is currently executable through the local ToolRegistry.",
      "type": "string",
      "enum": [
        "available",
        "unavailable"
      ]
    },
    "ToolDescriptor": {
      "description": "Canonical tool metadata. Provider adapters, UI capability reports, and the executor share these descriptors so unsupported tools are visible but never advertised as callable success paths.",
      "type": "object",
      "required": [
        "availability",
        "description",
        "display_name",
        "input_schema",
        "name",
        "permission",
        "reason_code",
        "schema"
      ],
      "properties": {
        "availability": {
          "$ref": "#/definitions/ToolAvailability"
        },
        "description": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_schema": true,
        "name": {
          "type": "string"
        },
        "permission": {
          "$ref": "#/definitions/ToolPermission"
        },
        "reason_code": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        }
      }
    },
    "ToolPermission": {
      "description": "Per-tool permission (§19.7). Risk rises from `Deny` to `Allow`.",
      "type": "string",
      "enum": [
        "deny",
        "read_only",
        "ask",
        "allow"
      ]
    }
  }
}
