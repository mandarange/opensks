{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeGraphRecord",
  "type": "object",
  "required": [
    "content_hash",
    "id",
    "kind",
    "line",
    "name",
    "path",
    "schema"
  ],
  "properties": {
    "content_hash": {
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/CodeGraphNodeKind"
    },
    "line": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "name": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    }
  },
  "definitions": {
    "CodeGraphNodeKind": {
      "type": "string",
      "enum": [
        "file",
        "symbol",
        "import",
        "test",
        "route"
      ]
    }
  }
}
