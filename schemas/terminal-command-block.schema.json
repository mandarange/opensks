{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TerminalCommandBlock",
  "type": "object",
  "required": [
    "block_id",
    "command_redacted",
    "cwd_redacted",
    "redacted",
    "schema",
    "session_id",
    "started_at_ms"
  ],
  "properties": {
    "block_id": {
      "type": "string"
    },
    "command_redacted": {
      "type": "string"
    },
    "cwd_redacted": {
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ],
      "format": "int32"
    },
    "finished_at_ms": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "redacted": {
      "type": "boolean"
    },
    "schema": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "started_at_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "stderr_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "stdout_digest": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
