{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReleaseProof",
  "type": "object",
  "required": [
    "fresh_clone_checked",
    "fresh_install_checked",
    "notarized",
    "rollback_plan_ref",
    "schema",
    "signed_app",
    "status",
    "upgrade_checked",
    "version"
  ],
  "properties": {
    "artifact_digest_gate_passed": {
      "default": false,
      "type": "boolean"
    },
    "artifact_digests": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReleaseArtifactDigest"
      }
    },
    "blockers": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReleaseProofBlocker"
      }
    },
    "fresh_clone_checked": {
      "type": "boolean"
    },
    "fresh_install_checked": {
      "type": "boolean"
    },
    "missing_artifacts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notarized": {
      "type": "boolean"
    },
    "rollback_plan_ref": {
      "type": "string"
    },
    "same_sha_artifact_binding": {
      "default": false,
      "type": "boolean"
    },
    "schema": {
      "type": "string"
    },
    "signed_app": {
      "type": "boolean"
    },
    "signing_evidence": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/ReleaseSigningEvidence"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_commit_sha": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "$ref": "#/definitions/TrustStatus"
    },
    "upgrade_checked": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    },
    "workspace_dirty": {
      "default": false,
      "type": "boolean"
    }
  },
  "definitions": {
    "ReleaseArtifactDigest": {
      "type": "object",
      "required": [
        "name",
        "path",
        "present",
        "required"
      ],
      "properties": {
        "digest": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "source_commit_sha": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ReleaseProofBlocker": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "ReleaseSigningEvidence": {
      "type": "object",
      "required": [
        "app_bundle_path",
        "checked",
        "notarized",
        "production_signed"
      ],
      "properties": {
        "app_bundle_path": {
          "type": "string"
        },
        "cd_hash": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "checked": {
          "type": "boolean"
        },
        "codesign_status": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "diagnostic": {
          "default": "",
          "type": "string"
        },
        "identifier": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "notarization_status": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "notarized": {
          "type": "boolean"
        },
        "production_signed": {
          "type": "boolean"
        },
        "signature": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "team_identifier": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TrustStatus": {
      "type": "string",
      "enum": [
        "verified",
        "verified_with_partial_evidence",
        "not_verified",
        "stale",
        "partial",
        "unavailable"
      ]
    }
  }
}
