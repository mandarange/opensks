{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompiledPlan",
  "type": "object",
  "required": [
    "dependency_index",
    "graph_hash",
    "graph_id",
    "graph_version",
    "plan_hash",
    "proof_contract",
    "resource_plan",
    "schema"
  ],
  "properties": {
    "approval_points": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ApprovalPoint"
      }
    },
    "dependency_index": {
      "$ref": "#/definitions/DependencyIndex"
    },
    "diagnostics": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/CompileDiagnostic"
      }
    },
    "graph_hash": {
      "type": "string"
    },
    "graph_id": {
      "type": "string"
    },
    "graph_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "plan_hash": {
      "type": "string"
    },
    "proof_contract": {
      "$ref": "#/definitions/CompletionContract"
    },
    "repair_plan": {
      "default": {
        "actions": [],
        "bounded": true,
        "groups": [],
        "max_iterations": 0,
        "reason_code": "no_repairs_required"
      },
      "allOf": [
        {
          "$ref": "#/definitions/CompileRepairPlan"
        }
      ]
    },
    "resource_plan": {
      "$ref": "#/definitions/ResourcePlan"
    },
    "schema": {
      "type": "string"
    },
    "shard_policy": {
      "anyOf": [
        {
          "$ref": "#/definitions/PlannerShardPolicy"
        },
        {
          "type": "null"
        }
      ]
    },
    "work_templates": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/WorkTemplate"
      }
    }
  },
  "definitions": {
    "ApprovalPoint": {
      "type": "object",
      "required": [
        "node_id",
        "reason_code",
        "scope"
      ],
      "properties": {
        "node_id": {
          "type": "string"
        },
        "reason_code": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        }
      }
    },
    "CapabilityRequirements": {
      "type": "object",
      "required": [
        "code",
        "image_edit",
        "image_output",
        "structured_output",
        "text",
        "tool_use",
        "vision_input"
      ],
      "properties": {
        "code": {
          "type": "boolean"
        },
        "image_edit": {
          "type": "boolean"
        },
        "image_output": {
          "type": "boolean"
        },
        "structured_output": {
          "type": "boolean"
        },
        "text": {
          "type": "boolean"
        },
        "tool_use": {
          "type": "boolean"
        },
        "vision_input": {
          "type": "boolean"
        }
      }
    },
    "CompileDiagnostic": {
      "type": "object",
      "required": [
        "message",
        "reason_code",
        "severity"
      ],
      "properties": {
        "edge_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "node_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason_code": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/definitions/DiagnosticSeverity"
        }
      }
    },
    "CompileRepairAction": {
      "type": "object",
      "required": [
        "action",
        "description",
        "diagnostic_reason_code",
        "evidence_required",
        "id"
      ],
      "properties": {
        "action": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "diagnostic_reason_code": {
          "type": "string"
        },
        "evidence_required": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "target_edge_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "target_node_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "CompileRepairGroup": {
      "type": "object",
      "required": [
        "description",
        "group_kind",
        "id"
      ],
      "properties": {
        "action_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "diagnostic_reason_codes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edge_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "group_kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "node_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "CompileRepairPlan": {
      "type": "object",
      "required": [
        "bounded",
        "max_iterations",
        "reason_code"
      ],
      "properties": {
        "actions": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/CompileRepairAction"
          }
        },
        "bounded": {
          "type": "boolean"
        },
        "groups": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/CompileRepairGroup"
          }
        },
        "max_iterations": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "reason_code": {
          "type": "string"
        }
      }
    },
    "CompletionContract": {
      "type": "object",
      "required": [
        "evidence_required"
      ],
      "properties": {
        "evidence_required": {
          "type": "boolean"
        },
        "final_seal_node_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_requirement_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirements": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProofRequirement"
          }
        }
      }
    },
    "DependencyIndex": {
      "type": "object",
      "properties": {
        "prerequisites": {
          "default": {},
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "DiagnosticSeverity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error"
      ]
    },
    "PlannerShardPolicy": {
      "type": "object",
      "required": [
        "candidate_selection_policy",
        "id",
        "implementation_shard_count",
        "max_parallelism",
        "role_count",
        "schema",
        "source",
        "verifier_shard_count"
      ],
      "properties": {
        "candidate_selection_policy": {
          "type": "string"
        },
        "evidence_refs": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "implementation_shard_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "max_parallelism": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "required_gates": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "role_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "schema": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "verifier_shard_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ProofRequirement": {
      "type": "object",
      "required": [
        "description",
        "evidence_required",
        "id"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "evidence_refs": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_required": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "source_node_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ResourcePlan": {
      "type": "object",
      "required": [
        "max_parallelism",
        "requires_external_side_effect_approval",
        "requires_git_worktree",
        "requires_image"
      ],
      "properties": {
        "max_parallelism": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "requires_external_side_effect_approval": {
          "type": "boolean"
        },
        "requires_git_worktree": {
          "type": "boolean"
        },
        "requires_image": {
          "type": "boolean"
        }
      }
    },
    "WorkKind": {
      "type": "string",
      "enum": [
        "planning",
        "model_inference",
        "tool_execution",
        "write_candidate",
        "verification",
        "integration",
        "approval",
        "external_side_effect"
      ]
    },
    "WorkTemplate": {
      "type": "object",
      "required": [
        "capability_requirements",
        "id",
        "kind",
        "node_id"
      ],
      "properties": {
        "capability_requirements": {
          "$ref": "#/definitions/CapabilityRequirements"
        },
        "dependencies": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/WorkKind"
        },
        "node_id": {
          "type": "string"
        },
        "requirement_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "shard_policy_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "shard_policy_required_source_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "shard_policy_required_verifier_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "shard_policy_selection_policy": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
