{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OutboxItem",
  "type": "object",
  "required": [
    "action",
    "approval_required",
    "id",
    "idempotency_key",
    "protected_branch",
    "schema",
    "state",
    "target"
  ],
  "properties": {
    "action": {
      "$ref": "#/definitions/OutboxAction"
    },
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "attempt_count": {
      "default": 0,
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "last_reason_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "protected_branch": {
      "type": "boolean"
    },
    "schema": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "target": {
      "type": "string"
    }
  },
  "definitions": {
    "OutboxAction": {
      "type": "string",
      "enum": [
        "commit",
        "push",
        "pull_request",
        "external_send"
      ]
    }
  }
}
