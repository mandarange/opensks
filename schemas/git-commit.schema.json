{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitCommit",
  "description": "The result of a local commit.",
  "type": "object",
  "required": [
    "commit",
    "committed",
    "schema"
  ],
  "properties": {
    "commit": {
      "type": "string"
    },
    "committed": {
      "type": "boolean"
    },
    "integration_candidate_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "integration_final_diff_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "integration_final_diff_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "integration_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "paths": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewed_staged_diff_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewed_staged_diff_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema": {
      "type": "string"
    }
  }
}
