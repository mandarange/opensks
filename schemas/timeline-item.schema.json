{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimelineItem",
  "description": "One durable timeline entry. `payload` is already secret-redacted; the DB column is `payload_redacted_json`.",
  "type": "object",
  "required": [
    "conversation_id",
    "created_at_ms",
    "id",
    "kind",
    "payload",
    "project_id",
    "schema",
    "sequence",
    "state",
    "updated_at_ms"
  ],
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "created_at_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/TimelineItemKind"
    },
    "payload": true,
    "project_id": {
      "type": "string"
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "format": "int64"
    },
    "state": {
      "type": "string"
    },
    "turn_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "TimelineItemKind": {
      "description": "The kind of a durable conversation timeline item (§11.1).",
      "type": "string",
      "enum": [
        "user_message",
        "assistant_message",
        "plan",
        "tool_call",
        "worker",
        "patch",
        "verification",
        "approval",
        "commit_receipt",
        "push_receipt",
        "image_artifact",
        "warning",
        "error"
      ]
    }
  }
}
