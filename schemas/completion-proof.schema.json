{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompletionProof",
  "type": "object",
  "required": [
    "coverage",
    "generated_at",
    "id",
    "run_id",
    "schema",
    "status"
  ],
  "properties": {
    "claims": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProofClaim"
      }
    },
    "coverage": {
      "$ref": "#/definitions/CoverageSeal"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "status": {
      "$ref": "#/definitions/TrustStatus"
    }
  },
  "definitions": {
    "CoverageSeal": {
      "type": "object",
      "required": [
        "covered",
        "final_seal_allowed",
        "required"
      ],
      "properties": {
        "covered": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "final_seal_allowed": {
          "type": "boolean"
        },
        "required": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "uncovered_requirement_ids": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ProofClaim": {
      "type": "object",
      "required": [
        "id",
        "status",
        "text"
      ],
      "properties": {
        "evidence_refs": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/TrustStatus"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "TrustStatus": {
      "type": "string",
      "enum": [
        "verified",
        "verified_with_partial_evidence",
        "not_verified",
        "stale",
        "partial",
        "unavailable"
      ]
    }
  }
}
