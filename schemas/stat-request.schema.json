{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StatRequest",
  "description": "Request to stat a workspace entry without reading its contents.",
  "type": "object",
  "required": [
    "schema",
    "workspace_relative_path"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "workspace_relative_path": {
      "type": "string"
    }
  }
}
