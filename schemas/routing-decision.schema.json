{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RoutingDecision",
  "type": "object",
  "required": [
    "id",
    "model_snapshot_hash",
    "reason_code",
    "schema",
    "status"
  ],
  "properties": {
    "eligible_model_ids": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string"
    },
    "model_snapshot_hash": {
      "type": "string"
    },
    "reason_code": {
      "type": "string"
    },
    "rejected_models": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ModelRejection"
      }
    },
    "route_receipt": {
      "anyOf": [
        {
          "$ref": "#/definitions/ModelRouteReceipt"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema": {
      "type": "string"
    },
    "selected_model_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "$ref": "#/definitions/RoutingStatus"
    }
  },
  "definitions": {
    "CapabilityRequirements": {
      "type": "object",
      "required": [
        "code",
        "image_edit",
        "image_output",
        "structured_output",
        "text",
        "tool_use",
        "vision_input"
      ],
      "properties": {
        "code": {
          "type": "boolean"
        },
        "image_edit": {
          "type": "boolean"
        },
        "image_output": {
          "type": "boolean"
        },
        "structured_output": {
          "type": "boolean"
        },
        "text": {
          "type": "boolean"
        },
        "tool_use": {
          "type": "boolean"
        },
        "vision_input": {
          "type": "boolean"
        }
      }
    },
    "ModelLimits": {
      "type": "object",
      "properties": {
        "max_concurrency": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "max_input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "max_output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "requests_per_minute": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "tokens_per_minute": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ModelRejection": {
      "type": "object",
      "required": [
        "model_id",
        "reason_code"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "reason_code": {
          "type": "string"
        }
      }
    },
    "ModelRouteReceipt": {
      "type": "object",
      "required": [
        "effective_limits",
        "reason_code",
        "registry_revision",
        "requested_capabilities"
      ],
      "properties": {
        "effective_limits": {
          "$ref": "#/definitions/ModelLimits"
        },
        "fallback_index": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "model_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason_code": {
          "type": "string"
        },
        "registry_revision": {
          "type": "string"
        },
        "requested_capabilities": {
          "$ref": "#/definitions/CapabilityRequirements"
        }
      }
    },
    "RoutingStatus": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "blocked_missing_capability",
            "blocked_disabled",
            "blocked_policy",
            "blocked_provider_health"
          ]
        },
        {
          "description": "A user/thread setting requested a model or auto route, but no registry snapshot has validated provider/model/capability/health yet.",
          "type": "string",
          "enum": [
            "requested"
          ]
        },
        {
          "description": "A registry snapshot found an enabled compatible provider/model.",
          "type": "string",
          "enum": [
            "resolved"
          ]
        },
        {
          "description": "Secret resolution, policy, health/circuit, and concurrency admission are all satisfied; the request can be dispatched.",
          "type": "string",
          "enum": [
            "dispatch_ready"
          ]
        },
        {
          "description": "A provider request was actually sent.",
          "type": "string",
          "enum": [
            "dispatched"
          ]
        },
        {
          "description": "Legacy compatibility label. New product paths should prefer the staged statuses above and only use this for old receipts already persisted.",
          "type": "string",
          "enum": [
            "routed"
          ]
        }
      ]
    }
  }
}
