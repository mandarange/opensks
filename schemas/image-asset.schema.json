{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImageAsset",
  "type": "object",
  "required": [
    "content_hash",
    "height",
    "id",
    "model_id",
    "path",
    "provider_id",
    "schema",
    "temporary",
    "width"
  ],
  "properties": {
    "anchors": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/VisualAnchor"
      }
    },
    "before_asset_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_hash": {
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "height": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "temporary": {
      "type": "boolean"
    },
    "width": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "VisualAnchor": {
      "type": "object",
      "required": [
        "height",
        "width",
        "x",
        "y"
      ],
      "properties": {
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "x": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "y": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
