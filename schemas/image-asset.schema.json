{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImageAsset",
  "type": "object",
  "required": [
    "content_hash",
    "height",
    "id",
    "model_id",
    "path",
    "provider_id",
    "schema",
    "temporary",
    "width"
  ],
  "properties": {
    "anchors": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/VisualAnchor"
      }
    },
    "before_asset_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_hash": {
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "height": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "provenance_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider_id": {
      "type": "string"
    },
    "route_receipt": {
      "anyOf": [
        {
          "$ref": "#/definitions/ModelRouteReceipt"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema": {
      "type": "string"
    },
    "temporary": {
      "type": "boolean"
    },
    "width": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "CapabilityRequirements": {
      "type": "object",
      "required": [
        "code",
        "image_edit",
        "image_output",
        "structured_output",
        "text",
        "tool_use",
        "vision_input"
      ],
      "properties": {
        "code": {
          "type": "boolean"
        },
        "image_edit": {
          "type": "boolean"
        },
        "image_output": {
          "type": "boolean"
        },
        "structured_output": {
          "type": "boolean"
        },
        "text": {
          "type": "boolean"
        },
        "tool_use": {
          "type": "boolean"
        },
        "vision_input": {
          "type": "boolean"
        }
      }
    },
    "ModelLimits": {
      "type": "object",
      "properties": {
        "max_concurrency": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "max_input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "max_output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "requests_per_minute": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "tokens_per_minute": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ModelRouteReceipt": {
      "type": "object",
      "required": [
        "effective_limits",
        "reason_code",
        "registry_revision",
        "requested_capabilities"
      ],
      "properties": {
        "effective_limits": {
          "$ref": "#/definitions/ModelLimits"
        },
        "fallback_index": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "model_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason_code": {
          "type": "string"
        },
        "registry_revision": {
          "type": "string"
        },
        "requested_capabilities": {
          "$ref": "#/definitions/CapabilityRequirements"
        }
      }
    },
    "VisualAnchor": {
      "type": "object",
      "required": [
        "height",
        "width",
        "x",
        "y"
      ],
      "properties": {
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "x": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "y": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
