{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionEventEnvelope",
  "type": "object",
  "required": [
    "actor",
    "id",
    "kind",
    "occurred_at",
    "payload",
    "run_id",
    "schema",
    "sensitivity",
    "sequence"
  ],
  "properties": {
    "actor": {
      "type": "string"
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/EventKind"
    },
    "occurred_at": {
      "type": "string"
    },
    "payload": true,
    "run_id": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "sensitivity": {
      "$ref": "#/definitions/Sensitivity"
    },
    "sequence": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "EventKind": {
      "type": "string",
      "enum": [
        "run_started",
        "run_paused",
        "run_resumed",
        "run_cancelled",
        "steering_requested",
        "approval_requested",
        "approval_approved",
        "approval_denied",
        "work_item_queued",
        "work_item_leased",
        "work_item_running",
        "work_item_completed",
        "lease_heartbeat",
        "lease_expired",
        "verification_passed",
        "verification_failed",
        "snapshot_written",
        "unknown"
      ]
    },
    "Sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "secret"
      ]
    }
  }
}
