{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntegrationApplyReceipt",
  "type": "object",
  "required": [
    "approval_required",
    "candidate_id",
    "candidate_ref",
    "content_redacted",
    "final_diff_ref",
    "generated_at_ms",
    "id",
    "integration_ref",
    "main_workspace_modified",
    "patch_ref",
    "path_redacted",
    "reason_code",
    "receipt_ref",
    "run_id",
    "schema",
    "state",
    "verifier_passed"
  ],
  "properties": {
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_policy_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "candidate_id": {
      "type": "string"
    },
    "candidate_ref": {
      "type": "string"
    },
    "cleanup_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_redacted": {
      "type": "boolean"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "final_diff_ref": {
      "type": "string"
    },
    "generated_at_ms": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "id": {
      "type": "string"
    },
    "integration_ref": {
      "type": "string"
    },
    "main_workspace_modified": {
      "type": "boolean"
    },
    "patch_ref": {
      "type": "string"
    },
    "path_redacted": {
      "type": "boolean"
    },
    "reason_code": {
      "type": "string"
    },
    "receipt_ref": {
      "type": "string"
    },
    "repair_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "seal_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "state": {
      "type": "string"
    },
    "target_paths": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "turn_settings": {
      "anyOf": [
        {
          "$ref": "#/definitions/IntegrationTurnSettingsSnapshot"
        },
        {
          "type": "null"
        }
      ]
    },
    "verification_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "verifier_passed": {
      "type": "boolean"
    }
  },
  "definitions": {
    "ExecutionMode": {
      "description": "Where a turn is allowed to write (§5.4). `Cloud` is reserved and hidden until a real adapter exists.",
      "type": "string",
      "enum": [
        "local",
        "worktree",
        "read_only",
        "cloud"
      ]
    },
    "IntegrationTurnSettingsSnapshot": {
      "type": "object",
      "required": [
        "approval_policy_id",
        "execution_mode",
        "max_parallelism",
        "model",
        "pipeline_id",
        "reasoning_effort",
        "tool_policy_id",
        "verifier_count"
      ],
      "properties": {
        "approval_policy_id": {
          "type": "string"
        },
        "cost_budget_usd": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_mode": {
          "$ref": "#/definitions/ExecutionMode"
        },
        "graph_revision": {
          "type": [
            "string",
            "null"
          ]
        },
        "image_model_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "max_parallelism": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "model": {
          "$ref": "#/definitions/ModelSelection"
        },
        "pipeline_id": {
          "type": "string"
        },
        "reasoning_effort": {
          "$ref": "#/definitions/ReasoningEffort"
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "token_budget": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "tool_policy_id": {
          "type": "string"
        },
        "verifier_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ModelSelection": {
      "description": "Model choice for a turn/thread. A single configured model auto-selects.",
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "fallback_model_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mode": {
          "$ref": "#/definitions/ModelSelectionMode"
        },
        "model_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ModelSelectionMode": {
      "description": "Whether the model is auto-routed or pinned by the user.",
      "type": "string",
      "enum": [
        "auto",
        "pinned"
      ]
    },
    "ReasoningEffort": {
      "description": "User-facing reasoning effort. Adapters map these to provider-specific knobs; an adapter that cannot honour a value reports `unsupported` rather than silently ignoring it (§5.3).",
      "type": "string",
      "enum": [
        "quick",
        "standard",
        "deep",
        "maximum"
      ]
    }
  }
}
