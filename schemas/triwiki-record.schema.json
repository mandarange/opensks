{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TriWikiRecord",
  "type": "object",
  "required": [
    "body",
    "id",
    "kind",
    "redacted",
    "schema",
    "shard",
    "title"
  ],
  "properties": {
    "body": {
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/TriWikiRecordKind"
    },
    "redacted": {
      "type": "boolean"
    },
    "schema": {
      "type": "string"
    },
    "shard": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "title": {
      "type": "string"
    }
  },
  "definitions": {
    "TriWikiRecordKind": {
      "type": "string",
      "enum": [
        "claim",
        "decision",
        "glossary",
        "wrongness",
        "architecture"
      ]
    }
  }
}
