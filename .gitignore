# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/
swift/.build/

# >>> OpenSKS managed local state
.opensks/runtime/
.opensks/cache/
.opensks/design-cache/
.opensks/tmp/
.opensks/logs/
.opensks/secrets/
.opensks/worktrees/
.opensks/workers/
.opensks/macos/
.opensks/providers/local/
.opensks/pipelines/compiled/
.opensks/wiki/indexes/
.opensks/wiki/context-packs/generated/
.opensks/history/raw/
.opensks/assets/candidates/
# Design-system import scratch is transient; the tracked packages under
# .opensks/design-systems/** are explicitly NOT ignored (see below).
*.import-tmp
# PR-042 vault: raw transcripts and any plaintext transcript stores stay LOCAL.
# Sanitized summaries under .opensks/summaries/ are git-trackable (re-asserted
# below). The .age ciphertext vaults are encrypted, but we ignore them by
# default so an opt-in export does not silently commit a binary blob; promote a
# specific .age by force-adding it if you intend to share it.
*.plaintext
*.transcript
.opensks/transcripts/
.opensks/vaults/
# <<< OpenSKS managed local state

# Shared, tracked design-system packages must remain in version control so the
# design registry can discover them. Never ignore them; re-assert in case a
# broader rule above would otherwise shadow the directory.
!.opensks/design-systems/
!.opensks/design-systems/**

# PR-042: sanitized, secret-redacted conversation summaries are portable and
# MUST stay in version control. Re-assert in case a broader rule shadows them.
!.opensks/summaries/
!.opensks/summaries/**

# OpenSKS compatibility artifact planes remain local until promoted by a
# later store/history migration.
.opensks/acceptance/
.opensks/app/
.opensks/app-use/
.opensks/auth/
.opensks/bench/
.opensks/browser/
.opensks/computer-use/
.opensks/design/
.opensks/gc/
.opensks/git/
.opensks/hooks/
.opensks/reasoning/
.opensks/release/
.opensks/mcp/
.opensks/missions/
