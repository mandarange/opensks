# Architecture ownership guardrail caps — PR-020 Baseline Seal.
#
# These caps freeze the root monolith at its baseline size so new domain code
# lands in crates/opensks-*, not in src/lib.rs. See docs/architecture-ownership.md.
#
# Policy:
#   - LOWERING a cap is always allowed (it records real progress on the
#     monolith-reduction milestones) and never needs an exception.
#   - RAISING a cap requires a reviewer-approved justification file under
#     docs/architecture-exceptions/ in the same pull request.
#
# Sourced by scripts/check-architecture-ownership.sh (plain KEY=VALUE shell).

# src/lib.rs line ceiling. Baseline ad18654 = 20102 lines; zero growth permitted.
SRC_LIB_RS_MAX_LINES=20102

# src/main.rs must stay a thin entry shim (baseline = 57 lines).
MAIN_RS_MAX_LINES=80
